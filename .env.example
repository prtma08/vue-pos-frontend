# API Configuration
VITE_API_BASE_URL=http://localhost:3001

# App Configuration
VITE_APP_NAME=POS System
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_MEMBER_CREATION=true
VITE_ENABLE_SUPERVISOR_AUTH=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_EXPORT_PDF=true
VITE_ENABLE_EXPORT_EXCEL=true

# Thresholds
VITE_SUPERVISOR_AUTH_THRESHOLD=100000
VITE_LOW_STOCK_THRESHOLD=10
VITE_MAX_PENDING_ORDERS=5

# Performance
VITE_REQUEST_TIMEOUT=10000
VITE_DEBOUNCE_DELAY=300
